# Django
SECRET_KEY=your-secret-key-here
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Database (leave empty for SQLite in dev)
DATABASE_URL=

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# Honeypot Deception Engine (Phase 3)
# Master switch — set False to disable honeypot generation on registration
HONEYPOT_ENABLED=True
# Enable local LLM generation for new registrations when available
HONEYPOT_USE_LLM_ON_REGISTRATION=True
# Backend: "ollama" (recommended), "auto", "transformers", "fallback"
HONEYPOT_LLM_BACKEND=ollama
# Ollama settings (only used if Ollama backend is active)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3
OLLAMA_TIMEOUT=30
# HuggingFace Transformers model name
HONEYPOT_TRANSFORMERS_MODEL=distilgpt2
# Number of fake decoy passwords to generate per user
HONEYPOT_DECOY_PASSWORDS=4

# Honeypot Breach Alert — Gmail SMTP (Phase 4)
# Gmail SMTP server (default: smtp.gmail.com)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
# Your Gmail address (sender)
SMTP_EMAIL=your-email@gmail.com
# Gmail App Password (NOT your regular password)
# Generate at: https://myaccount.google.com/apppasswords
SMTP_PASSWORD=your-app-password-here
# Display name for outgoing alerts
SMTP_FROM_NAME=Abhedya Security
SMTP_USE_TLS=True
SMTP_TIMEOUT=30
# Max breach alerts per user per hour (prevents flooding)
ALERT_RATE_LIMIT=5
